# ===== DATABASE =====
DATABASE_URL=postgresql+asyncpg://vpn_user:vpn_password@postgres:5432/vpn_db
REDIS_URL=redis://redis:6379/0

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_API_HASH=YOUR_API_HASH
TELEGRAM_APP_ID=YOUR_APP_ID

# ===== BACKEND API =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long

# ===== ENCRYPTION =====
# Generate with: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
FERNET_KEY=your-fernet-key-here

# ===== WG MANAGER =====
WG_MANAGER_HOST=wg-manager
WG_MANAGER_PORT=8001
WG_MANAGER_SECRET=wg-manager-secret-key

# ===== VPN SERVERS =====
# Format: host1:port1,host2:port2
WG_SERVERS=wireguard-1:51820,wireguard-2:51820

# ===== MONITORING =====
LOG_LEVEL=INFO
SENTRY_DSN=

# ===== PRICING (in Telegram Stars) =====
TRIAL_DAYS=7
WEEKLY_PRICE=50
MONTHLY_PRICE=150

# ===== FEATURES =====
MAX_DEVICES_PER_USER=3
SUBSCRIPTION_CHECK_INTERVAL=300  # 5 minutes
NOTIFICATION_HOURS_BEFORE=24

# ===== NGINX =====
DOMAIN=vpn.example.com

# ===== POSTGRES =====
POSTGRES_USER=vpn_user
POSTGRES_PASSWORD=vpn_password
POSTGRES_DB=vpn_db
